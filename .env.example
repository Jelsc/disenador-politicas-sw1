#!/usr/bin/env env
# ==========================================
# ENTORNO DE DESPLIEGUE (APP_ENV)
# ==========================================
# Usar 'local' para desarrollo en tu PC
# Usar 'prod' para la nube en Azure
APP_ENV=local

# ==========================================
# DOMINIOS (Nginx / Certbot en producción)
# ==========================================
FRONTEND_DOMAIN=app-primerpacialsw.duckdns.org
API_DOMAIN=api-primerpacialsw.duckdns.org
CERTBOT_EMAIL=tu_correo@gmail.com
# Nombre del certificado generado por Certbot.
# Si emitís un solo certificado SAN para varios dominios,
# Certbot suele guardarlo bajo el PRIMER dominio que pasaste en -d.
CERTBOT_CERT_NAME=app-primerpacialsw.duckdns.org

# ==========================================
# URLS DE CONEXIÓN
# ==========================================

# ---> OPCIÓN A: CONFIGURACIÓN LOCAL
# En local TODO entra por Nginx en http://localhost
API_URL=http://localhost/api
AI_URL=http://localhost/ai
WS_URL=ws://localhost/ws
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80,http://localhost

# ---> OPCIÓN B: CONFIGURACIÓN NUBE / AZURE
# Si usás prod, reemplazá el bloque local por este:
# API_URL=https://api-primerpacialsw.duckdns.org/api
# AI_URL=https://api-primerpacialsw.duckdns.org/ai
# WS_URL=wss://api-primerpacialsw.duckdns.org/ws
# ALLOWED_ORIGINS=https://app-primerpacialsw.duckdns.org

# ==========================================
# MONGODB (MVP)
# ==========================================
# Para este MVP MongoDB queda expuesto en localhost:27017
# para facilitar conexiones con TablePlus / Compass.
# Conexión externa sugerida:
# mongodb://localhost:27017

# ==========================================
# AI LOCAL / OLLAMA
# ==========================================
# No consume servicios externos en runtime. El modelo vive dentro de la VM.
# Para esta VM (2 vCPU / 8GB RAM), usar modelo chico.
AI_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=45
AI_NEURAL_MAX_RULE_NODES=80

# Primera vez en el servidor, después de levantar docker compose:
# docker exec -it tuapp-ollama ollama pull qwen2.5:3b-instruct
