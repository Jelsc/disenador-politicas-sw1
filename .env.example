# ==========================================
# ENTORNO DE DESPLIEGUE (APP_ENV)
# ==========================================
# Usar 'local' para desarrollo en tu PC (http://localhost)
# Usar 'prod' para la nube en Azure (fuerza HTTPS con Let's Encrypt)
APP_ENV=local

# ==========================================
# DOMINIOS (Utilizados por Nginx y Certbot en prod)
# ==========================================
FRONTEND_DOMAIN=app-primerpacialsw.duckdns.org
API_DOMAIN=api-primerpacialsw.duckdns.org
CERTBOT_EMAIL=tu_correo@gmail.com

# ==========================================
# URLS DE CONEXIÓN (Inyectadas al Frontend y CORS del Backend)
# ==========================================

# ---> OPCION A: CONFIGURACIÓN PARA LOCAL (Activa por defecto)
API_URL=http://localhost:8080/api
AI_URL=http://localhost:8000
WS_URL=ws://localhost:8080/ws
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80

# ---> OPCION B: CONFIGURACIÓN PARA NUBE / AZURE
# (Comentá la Opción A y descomentá esta bloque si APP_ENV=prod)
# API_URL=https://api-primerpacialsw.duckdns.org/api
# AI_URL=https://api-primerpacialsw.duckdns.org/ai
# WS_URL=wss://api-primerpacialsw.duckdns.org/ws
# ALLOWED_ORIGINS=https://app-primerpacialsw.duckdns.org